# ── PMC Overwatch — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Optional: Ollama model to use (default: mistral)
# Run "ollama pull mistral" to download the default model.
OLLAMA_MODEL=mistral

# Optional: Kokoro TTS voice and speed
# Voices: am_michael (deep male), am_adam (male), af_sarah (female)
# Model files auto-download on first run (~330MB)
TTS_VOICE=am_michael
TTS_SPEED=1.0

# Optional: Twitch integration (leave blank to disable)
TWITCH_TOKEN=
TWITCH_INITIAL_CHANNELS=

# Optional: Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
