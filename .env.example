# ── PMC Overwatch — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Ollama model to use (default: mistral)
# For better quality on 16GB+ Macs: mistral-small3.1
# Run "ollama pull <model>" to download.
OLLAMA_MODEL=mistral

# Ollama context window size (default: 4096)
# Higher = more conversation memory, but uses more RAM
OLLAMA_NUM_CTX=4096

# TTS voice — Kokoro voice ID (default: af_heart)
# Options: af_heart, af_sarah, af_bella, af_nicole, af_sky,
#          am_adam, am_michael, bf_emma, bf_isabella, bm_george, bm_lewis
TTS_VOICE=af_heart

# TTS speed — 1.0 = natural pace (default: 1.0)
TTS_SPEED=1.0

# TTS language/accent (default: en-us)
# Options: en-us, en-gb
TTS_LANG=en-us

# Whisper model for speech-to-text (default: large-v3-turbo)
# Options: tiny, base, small, medium, large-v3, large-v3-turbo
# Smaller = faster but less accurate. large-v3-turbo = best balance.
WHISPER_MODEL=large-v3-turbo

# Whisper compute type (default: int8)
# Options: int8, float16, float32. int8 is fastest on Apple Silicon.
WHISPER_COMPUTE_TYPE=int8

# Optional: Twitch integration (leave blank to disable)
TWITCH_TOKEN=
TWITCH_INITIAL_CHANNELS=

# Optional: Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
