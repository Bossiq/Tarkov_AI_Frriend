# ── PMC Overwatch — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── AI Model (Ollama) ─────────────────────────────────────────────
# Install Ollama from https://ollama.com then run: ollama pull <model>
# Recommended: qwen2.5:7b (best balance of speed + quality)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=4096

# ── Text-to-Speech ───────────────────────────────────────────────
# Primary: edge-tts (Microsoft Neural voices, auto-selected per language)
# Fallback: Kokoro (downloads ~100MB model on first run)
TTS_VOICE=af_heart
TTS_SPEED=1.1
TTS_LANG=en-us

# ── Speech-to-Text (faster-whisper) ─────────────────────────────
# Model: tiny (fastest), base (default), small, medium (most accurate)
# Compute: int8 (CPU), float16 (CUDA GPU)
# Language: en (default, most accurate), ru, ro, auto (may misdetect)
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en

# ── Twitch Integration (optional) ───────────────────────────────
# Leave blank to disable. Get a token from https://twitchapps.com/tmi/
TWITCH_TOKEN=
TWITCH_INITIAL_CHANNELS=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
