# ── PMC Overwatch — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── AI Model (Ollama) ─────────────────────────────────────────────
# Install Ollama from https://ollama.com then run: ollama pull <model>
# Recommended: qwen2.5:3b (fast, 2GB) or qwen2.5:7b (better, 5GB)
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_NUM_CTX=4096

# ── Text-to-Speech (Kokoro) ──────────────────────────────────────
# Model files download automatically on first run (~100MB total).
# Voice options: af_heart, af_sarah, af_bella, af_nicole, af_sky,
#                am_adam, am_michael, bf_emma, bf_isabella, bm_george
TTS_VOICE=af_heart
TTS_SPEED=1.2
TTS_LANG=en-us

# ── Speech-to-Text (faster-whisper) ─────────────────────────────
# Model options: tiny, base, small, medium, large-v3-turbo
# Compute: int8 (CPU), float16 (CUDA GPU)
# Device auto-detects CUDA. Set WHISPER_DEVICE=cpu to force CPU.
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8

# ── Twitch Integration (optional) ───────────────────────────────
# Leave blank to disable. Get a token from https://twitchapps.com/tmi/
TWITCH_TOKEN=
TWITCH_INITIAL_CHANNELS=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
