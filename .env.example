# ── PMC Overwatch — Environment Variables ──────────────────────────
# Copy this to .env and fill in your values.

# ── LLM Brain ────────────────────────────────────────────────────────
# Groq cloud API (primary — 250+ tokens/sec, free tier: 30 RPM)
# Get your free key at https://console.groq.com/keys
# If empty, falls back to Ollama local inference.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama local (fallback — auto-failover when Groq rate-limits)
# Install: https://ollama.com  →  ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=2048

# Google Gemini (2nd fallback — 1500 req/day free tier)
# Get your free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── TTS ──────────────────────────────────────────────────────────────
# Primary: edge-tts neural voices (auto-detected per language)
# Fallback: Kokoro ONNX (English only)
TTS_VOICE=af_heart
TTS_SPEED=1.1
TTS_LANG=en-us
EDGE_RATE=+0%

# ── STT ──────────────────────────────────────────────────────────────
# Whisper model size: tiny, base, small, medium
# Larger = more accurate but slower
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=float16
# Force transcription language (auto = detect per utterance)
# Set to 'ro' for Romanian, 'en' for English, 'ru' for Russian
WHISPER_LANGUAGE=auto

# ── Input Mode ───────────────────────────────────────────────────────
# auto   — continuous VAD listening (default)
# toggle — press PTT_KEY to start/stop recording
# push   — hold PTT_KEY to record, release to stop
INPUT_MODE=auto
PTT_KEY=f4

# ── Twitch ───────────────────────────────────────────────────────────
# Get a token at https://twitchtokengenerator.com
# Leave empty to disable Twitch integration.
TWITCH_TOKEN=
TWITCH_INITIAL_CHANNELS=

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Screen Capture (anti-cheat safe — uses same API as OBS) ──────────
# Uses Windows DXGI Desktop Duplication (identical to OBS Display Capture).
# BattlEye FAQ confirms: non-cheat tools are safe.
SCREEN_CAPTURE=true
SCREEN_MONITOR=1
SCREEN_FPS=1.0
SCREEN_COMMENTARY=true
SCREEN_COMMENTARY_INTERVAL=30

# ── Sound Effects ────────────────────────────────────────────────────
SFX_ENABLED=true
SFX_VOLUME=0.5

# ── Web Dashboard ────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8420
