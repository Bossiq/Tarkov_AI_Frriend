# ── PMC Overwatch — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Ollama model (default: qwen2.5:3b — balanced speed + knowledge)
# For fastest responses: qwen2.5:1.5b (1GB, less accurate)
# For best quality: mistral (7B, 4.4GB, slower)
# Run "ollama pull <model>" to download.
OLLAMA_MODEL=qwen2.5:3b

# Context window (default: 2048). Higher = more memory, slower.
OLLAMA_NUM_CTX=2048

# TTS voice — Kokoro voice ID (default: af_heart)
# Options: af_heart, af_sarah, af_bella, af_nicole, af_sky,
#          am_adam, am_michael, bf_emma, bf_isabella, bm_george
TTS_VOICE=af_heart

# TTS speed (default: 1.2). Higher = faster speech.
TTS_SPEED=1.2

# TTS language (default: en-us). Options: en-us, en-gb
TTS_LANG=en-us

# Whisper STT model (default: base)
# Options: tiny, base, small, medium, large-v3-turbo
WHISPER_MODEL=base

# Whisper compute type (default: int8)
WHISPER_COMPUTE_TYPE=int8

# Optional: Twitch integration (leave blank to disable)
TWITCH_TOKEN=
TWITCH_INITIAL_CHANNELS=

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
